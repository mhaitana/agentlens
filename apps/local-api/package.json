{
  "name": "@agentlens/local-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run"
  },
  "dependencies": {
    "@agentlens/domain": "workspace:*",
    "@agentlens/config": "workspace:*",
    "@agentlens/shared": "workspace:*",
    "@agentlens/database": "workspace:*",
    "@agentlens/recommendations": "workspace:*",
    "@agentlens/analysis-engine": "workspace:*",
    "@agentlens/reporting": "workspace:*",
    "@agentlens/otel-receiver": "workspace:*",
    "@agentlens/hook-collector": "workspace:*",
    "@agentlens/redaction": "workspace:*",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.0"
  }
}
