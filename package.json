{
  "name": "agentlens",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first, privacy-first analytics & coaching for AI coding agents.",
  "keywords": [
    "ai-agents",
    "claude-code",
    "analytics",
    "local-first",
    "privacy-first",
    "opentelemetry",
    "prompt-coaching",
    "developer-tools",
    "agent-analytics"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "github:mhaitana/agentlens.git",
    "directory": "."
  },
  "homepage": "https://github.com/mhaitana/agentlens#readme",
  "bugs": {
    "url": "https://github.com/mhaitana/agentlens/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.10.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.7.2"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
