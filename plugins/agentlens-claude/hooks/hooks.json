        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/scripts/hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionDenied": [
