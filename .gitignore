# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.turbo/
*.tsbuildinfo

# Vendored dashboard bundle (created by apps/cli prepack hook at publish time)
apps/cli/dashboard/

# Test / coverage
coverage/
test-results/
playwright-report/
playwright/.cache/

# AgentLens local data (never commit real usage data)
*.agentlens.sqlite
agentlens.sqlite
backups/
event-spool/
exports/
runtime/

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/

# EPCC workflow tracking files (local only — not part of the project source)
EPCC_EXPLORE.md
EPCC_PLAN.md
EPCC_CODE.md
EPCC_COMMIT.md
epcc-features.json
epcc-progress.md

# Changesets — changeset files MUST be committed so the Release workflow
# (changesets/action) can consume them and cut a version. (README.md is tracked
# like any other file; do not ignore .changeset/*.md.)

# Playwright (browsers pinned in-repo per §26 / user constraint)
.playwright-browsers/
test-results/
playwright-report/
